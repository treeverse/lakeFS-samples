# Local-development override for working against an UNPUBLISHED checkout of
# dvc-to-lakefs (instead of installing it from PyPI).
#
# Usage:
#   1. cp docker-compose.override.yml.example docker-compose.override.yml
#   2. Edit the volume path below to point at your local dvc-to-lakefs checkout.
#   3. docker compose up --build
#
# docker-compose.override.yml is git-ignored, so this never affects the
# published sample, which installs dvc-to-lakefs from PyPI by default.

services:
  jupyter-notebook:
    volumes:
      # Mount your local checkout (read-only) into the container.
      - /path/to/dvc-to-lakefs:/home/jovyan/dvc-to-lakefs-pkg:ro
    # Install the mounted package before launching Jupyter.
    command:
      - bash
      - -lc
      - "pip install /home/jovyan/dvc-to-lakefs-pkg && start-notebook.py"
